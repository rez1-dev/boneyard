{
  "name": "boneyard-js",
  "version": "1.6.3",
  "description": "Pixel-perfect skeleton loading screens. Wrap your component in <Skeleton> and boneyard snapshots the real DOM layout — no manual descriptors, no configuration.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./layout": {
      "types": "./dist/layout.d.ts",
      "import": "./dist/layout.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./svelte": {
      "types": "./dist/svelte.d.ts",
      "svelte": "./dist/Skeleton.svelte",
      "default": "./dist/Skeleton.svelte"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/Skeleton.vue",
      "default": "./dist/Skeleton.vue"
    },
    "./react-native": {
      "types": "./dist/native.d.ts",
      "default": "./dist/native.tsx"
    },
    "./native": {
      "types": "./dist/native.d.ts",
      "default": "./dist/native.tsx"
    },
    "./native-scan": {
      "types": "./dist/native-scan.d.ts",
      "default": "./dist/native-scan.tsx"
    }
  },
  "typesVersions": {
    ">4.0": {
      "index": [
        "./dist/index.d.ts"
      ],
      "layout": [
        "./dist/layout.d.ts"
      ],
      "react": [
        "./dist/react.d.ts"
      ],
      "svelte": [
        "./dist/svelte.d.ts"
      ],
      "vue": [
        "./dist/vue.d.ts"
      ]
    }
  },
  "bin": {
    "boneyard-js": "bin/cli.js"
  },
  "files": [
    "dist",
    "bin",
    "native.js",
    "native.d.ts",
    "native-scan.js",
    "native-scan.d.ts",
    "native-scan.js",
    "native-scan.d.ts"
  ],
  "scripts": {
    "build": "tsc && npm run copy-svelte && npm run copy-native && npm run copy-vue",
    "copy-svelte": "cp src/Skeleton.svelte dist/Skeleton.svelte && cp src/svelte.d.ts dist/svelte.d.ts",
    "copy-native": "cp src/native.tsx dist/native.tsx && cp src/react-native.tsx dist/react-native.tsx && cp src/native-scan.tsx dist/native-scan.tsx",
    "copy-vue": "cp src/Skeleton.vue dist/Skeleton.vue && cp src/vue.d.ts dist/vue.d.ts",
    "benchmark": "bun run scripts/benchmark-layout.ts",
    "test": "bun test",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "skeleton",
    "skeleton-screen",
    "loading",
    "placeholder",
    "react",
    "react-native",
    "vue",
    "zero-layout-shift"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xGF/boneyard"
  },
  "homepage": "https://github.com/0xGF/boneyard",
  "optionalDependencies": {
    "@chenglou/pretext": "^0.0.3"
  },
  "peerDependencies": {
    "react": ">=18",
    "svelte": ">=5",
    "react-native": ">=0.71",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "dependencies": {
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-native": "^0.73.0",
    "canvas": "^3.2.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "svelte": "^5.39.6",
    "typescript": "^5.7.0"
  }
}
